#  STAGE 5 — 30-DAY ROLLING FORECAST WITH MONTE CARLO
# ══════════════════════════════════════════════════════════════════════════════

def rolling_forecast(processed_df, best_model, scaler, feature_cols,
                     horizon=HORIZON, n_simulations=300):
    banner("STAGE 5 — 30-DAY ROLLING FORECAST WITH MONTE CARLO BANDS")

    X, y_ret, y_prc, y_dir = get_feature_matrix(processed_df)
    X_full_s = scaler.fit_transform(X)
    best_model.fit(X_full_s, y_ret)

    # Residual noise from last 252 training days
    preds_full  = best_model.predict(X_full_s)
    residuals   = (y_ret.values - preds_full)[-252:]
    noise_std   = residuals.std()

    last_price = processed_df["Gold_Close"].iloc[-1]
    last_date  = processed_df.index[-1]
    all_paths  = []

    for sim in range(n_simulations):
        prices = [last_price]
        sim_df = processed_df.copy()

        for step in range(1, horizon + 1):
            next_date = last_date + pd.tseries.offsets.BDay(step)
            row = {}
            latest = sim_df.iloc[-1]

            for col in feature_cols:
                row[col] = latest.get(col, 0.0)

            lag_series = sim_df["Gold_Close"]
            ret_series = lag_series.pct_change()

            for lag in [1, 2, 3, 5, 10, 21]:
                k = f"GoldRet_Lag_{lag}"
                if k in row and len(ret_series) >= lag:
                    row[k] = ret_series.iloc[-lag]
            for lag in [1, 2, 5, 10, 21]:
                k = f"Gold_Lag_{lag}"
                if k in row and len(lag_series) >= lag:
                    row[k] = lag_series.iloc[-lag]

            row["Month"]       = next_date.month
            row["DayOfWeek"]   = next_date.dayofweek
            row["Quarter"]     = next_date.quarter
            row["IsJanuary"]   = int(next_date.month == 1)
            row["IsSeptember"] = int(next_date.month == 9)

            row_df     = pd.DataFrame([row])[feature_cols]
            row_scaled = scaler.transform(row_df)
            pred_ret   = best_model.predict(row_scaled)[0]
            noise      = 0 if sim == 0 else np.random.normal(0, noise_std)
            new_price  = prices[-1] * (1 + pred_ret + noise)
            prices.append(new_price)

            new_row = sim_df.iloc[-1:].copy()
            new_row.index = [next_date]
            new_row["Gold_Close"]     = new_price
            new_row["Target_Price"]   = new_price
            new_row["Target_Return"]  = pred_ret + noise
            sim_df = pd.concat([sim_df, new_row])

        all_paths.append(prices[1:])

    all_paths = np.array(all_paths)
    fdates    = [last_date + pd.tseries.offsets.BDay(i) for i in range(1, horizon+1)]
    point_fc  = all_paths[0]

    prev_arr = np.concatenate([[last_price], point_fc[:-1]])
    forecast_df = pd.DataFrame({
        "Date":       fdates,
        "Forecast":   point_fc,
        "Lower_80":   np.percentile(all_paths, 10, axis=0),
        "Upper_80":   np.percentile(all_paths, 90, axis=0),
        "Lower_95":   np.percentile(all_paths,  2.5, axis=0),
        "Upper_95":   np.percentile(all_paths, 97.5, axis=0),
        "PctChange":  (point_fc - prev_arr) / prev_arr * 100,
        "Direction":  (point_fc > prev_arr).astype(int),
    }).set_index("Date")

    print(f"  Last known price : ${last_price:,.2f}")
    print(f"  30-day forecast  : ${point_fc[-1]:,.2f}  "
          f"({'▲' if point_fc[-1] > last_price else '▼'}"
          f" {abs(point_fc[-1]/last_price-1)*100:.1f}%)")
    return forecast_df, last_price


