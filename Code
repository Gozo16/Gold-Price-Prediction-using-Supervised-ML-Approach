def run_full_pipeline(start=START_DATE, end=END_DATE,
                      launch_widget=True, save_csv=True):
    """
    Run the complete Gold Prediction & Investor Intelligence pipeline.

    Usage in Colab:
        processed_df, results, best_name, forecast_df, signals = run_full_pipeline()
    """
    print("\n╔" + "═"*70 + "╗")
    print("║   GOLD PRICE PREDICTION & INVESTOR INTELLIGENCE TOOL  v2.0" + " "*10 + "║")
    print("║   University Final Project  ·  Complete ML Pipeline" + " "*18 + "║")
    print("╚" + "═"*70 + "╝")

    # ── Stages 1-3: Data ──────────────────────────────────────────────────────
    raw_df       = download_data(start, end)
    clean_df     = clean_data(raw_df)
    processed_df = engineer_features(clean_df)

    # ── Stage 4: Train ────────────────────────────────────────────────────────
    results, best_name, X_train, X_test, y_test, yp_test, scaler, feature_cols = \
        train_and_evaluate(processed_df)

    # Pick model object for forecasting
    if results[best_name]["model"] is not None:
        best_model = results[best_name]["model"]
    else:
        comp       = results[best_name].get("components", list(results.keys()))[0]
        best_model = results[comp]["model"]

    # ── Stage 5: Forecast ─────────────────────────────────────────────────────
    forecast_df, last_price = rolling_forecast(
        processed_df, best_model, scaler, feature_cols, horizon=HORIZON)

    # ── Stage 6: Signals ──────────────────────────────────────────────────────
    signals = generate_investor_signals(
        forecast_df, results, best_name, processed_df)

    # ── Stage 7: Visualize ────────────────────────────────────────────────────
    plot_all(processed_df, results, best_name, X_test, yp_test,
             forecast_df, signals, feature_cols, scaler)

    # ── Save CSVs ─────────────────────────────────────────────────────────────
    if save_csv:
        forecast_df.to_csv("gold_forecast_30day.csv")
        sig_df = forecast_df.copy()
        sig_df["Signal"] = sig_df["PctChange"].apply(
            lambda x: "BUY" if x > 0.15 else ("SELL" if x < -0.15 else "HOLD"))
        sig_df.to_csv("gold_forecast_with_signals.csv")
        print("\n  Forecast saved → gold_forecast_30day.csv")
        print("  Signals saved  → gold_forecast_with_signals.csv")

    # ── Stage 8: Widget ───────────────────────────────────────────────────────
    if launch_widget:
        launch_colab_tool(forecast_df, signals, results, best_name, processed_df)

    # ── Final Summary ─────────────────────────────────────────────────────────
    banner("PIPELINE COMPLETE — FINAL SUMMARY")
    r = results[best_name]
    print(f"""
  ✔ Best Model         : {best_name}
  ─────────────────────────────────────────────────────────────
  REGRESSION METRICS (price accuracy):
    MAE              : ${r['MAE']:,.2f}     avg absolute $ error per day
    RMSE             : ${r['RMSE']:,.2f}     penalises large errors more
    MAPE             : {r['MAPE']:.2f}%      % error vs actual price — KEY METRIC
    R² (Returns)     : {r['R2']:.4f}     1–2% on returns = academically significant
    R² (Prices)      : {r['R2_Price']:.4f}   context only — inflated by random-walk
    CV MAE           : ${r['CV_MAE']:,.2f}     cross-validated, no leakage

  DIRECTIONAL / CLASSIFICATION METRICS:
    Directional Acc  : {r['DirectionAcc']*100:.1f}%     % of UP/DOWN days correctly called
    Precision        : {r['Precision']*100:.1f}%     of predicted UPs, how many were right
    Recall           : {r['Recall']*100:.1f}%     of actual UPs, how many were caught
    F1 Score         : {r['F1']*100:.1f}%     harmonic mean of precision/recall
    AUC-ROC          : {r['AUC_ROC']:.3f}     ranking quality (>0.5 = better than random)
  ─────────────────────────────────────────────────────────────
  Figures saved   : fig1…fig12 + figA (confusion) + figB (table)
  Forecast CSV    : gold_forecast_30day.csv
  Signals CSV     : gold_forecast_with_signals.csv
  ─────────────────────────────────────────────────────────────
  ⓘ  Forecasts are probabilistic — not financial advice.
    """)

    return processed_df, results, best_name, forecast_df, signals


