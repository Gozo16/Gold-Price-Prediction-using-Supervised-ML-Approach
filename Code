    </style>"""

    display(HTML(STYLE + """
    <div class='header'>
      <h2 style='color:#D4AF37;margin:0 0 4px 0;'>◆ GOLD INVESTOR INTELLIGENCE TOOL</h2>
      <p style='margin:0;font-size:12px;color:#888;'>
        ML-powered signals · 30-day horizon · Select query type and hit Run
      </p>
    </div>"""))

    out = Output()

    query_type = widgets.ToggleButtons(
        options=["📅 Date Forecast","🟢 Best Buy Day","🔴 Best Sell Day",
                 "📊 All Model Metrics","⚠ Risk Assessment","📋 Full Report"],
        description="Query:", button_style="",
        style={"button_width":"140px","description_width":"60px"})

    horizon_slider = widgets.IntSlider(
        value=10, min=1, max=30, step=1, description="Days:",
        style={"description_width":"60px"},
        layout=widgets.Layout(width="320px"))

    date_options = [str(d.date()) for d in forecast_df.index]
    date_picker  = widgets.Dropdown(
        options=date_options, description="Date:",
        style={"description_width":"60px"},
        layout=widgets.Layout(width="220px"))

    run_btn = widgets.Button(
        description="▶  Run Query", button_style="",
        style={"button_color":"#D4AF37","font_weight":"bold"},
        layout=widgets.Layout(width="160px", height="36px"))

    display(VBox([HBox([query_type]), HBox([horizon_slider, date_picker, run_btn])]), out)

    def on_run(_):
        with out:
            clear_output(wait=True)
            qt     = query_type.value
            n_days = horizon_slider.value
            f_sub  = forecast_df.iloc[:n_days]
            lp     = signals["last_price"]

            if "Date Forecast" in qt:
                sel_dt = pd.Timestamp(date_picker.value)
                if sel_dt not in forecast_df.index:
                    display(HTML(STYLE+"<div class='card'><span class='red'>Date not in range.</span></div>")); return
                row = forecast_df.loc[sel_dt]
                chg = row["PctChange"]
                col = "green" if chg >= 0 else "red"
                arr = "▲" if chg >= 0 else "▼"
                display(HTML(STYLE + f"""
                <div class='card'>
                  <p class='gold'>📅 FORECAST FOR {sel_dt.strftime('%A, %d %B %Y')}</p>
                  <table>
                    <tr><th>Metric</th><th>Value</th></tr>
                    <tr><td>Forecast Price</td><td class='gold'>${row['Forecast']:,.2f}</td></tr>
                    <tr><td>Daily Change</td><td class='{col}'>{arr} {abs(chg):.2f}%</td></tr>
                    <tr><td>vs Current</td><td class='{col}'>{arr} ${row['Forecast']-lp:+,.2f}</td></tr>
                    <tr><td>Direction</td><td class='{col}'>{'UP ▲' if row['Direction']==1 else 'DOWN ▼'}</td></tr>
                    <tr><td>80% CI</td><td class='blue'>${row['Lower_80']:,.2f} – ${row['Upper_80']:,.2f}</td></tr>
                    <tr><td>95% CI</td><td>${row['Lower_95']:,.2f} – ${row['Upper_95']:,.2f}</td></tr>
                  </table>
                </div>"""))

            elif "Best Buy" in qt:
                d = f_sub["Forecast"].idxmin(); p = f_sub["Forecast"].min()
                display(HTML(STYLE + f"""
                <div class='card'>
                  <p class='gold'>🟢 BEST DAY TO BUY  (next {n_days} days)</p>
                  <table>
                    <tr><th>Metric</th><th>Value</th></tr>
                    <tr><td>Date</td><td class='green'>{d.strftime('%A, %d %B %Y')}</td></tr>
                    <tr><td>Forecast Price</td><td class='green'>${p:,.2f}</td></tr>
                    <tr><td>vs Current</td><td class='green'>{(p-lp)/lp*100:+.2f}%</td></tr>
