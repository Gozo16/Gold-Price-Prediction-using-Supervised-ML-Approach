def download_data(start=START_DATE, end=END_DATE):
    banner("STAGE 1 — DATA DOWNLOAD")
    TICKERS = {
        "GC=F":     {"Close":"Gold_Close","Open":"Gold_Open",
                     "High":"Gold_High","Low":"Gold_Low","Volume":"Gold_Volume"},
        "DX-Y.NYB": {"Close":"DXY"},
        "^TNX":     {"Close":"TreasuryYield"},
        "^GSPC":    {"Close":"SP500"},
        "^VIX":     {"Close":"VIX"},
        "CL=F":     {"Close":"CrudeOil"},
        "GLD":      {"Close":"GLD_ETF"},
        "TLT":      {"Close":"TLT_Bond"},
    }
    frames = []
    for ticker, col_map in TICKERS.items():
        print(f"  Downloading  {ticker:<14} → {list(col_map.values())}")
        try:
            df = yf.download(ticker, start=start, end=end,
                             auto_adjust=True, progress=False)
            if df.empty:
                print(f"    ⚠ No data for {ticker}")
                continue
            if isinstance(df.columns, pd.MultiIndex):
                df.columns = df.columns.get_level_values(0)
            subset = df[[c for c in col_map if c in df.columns]].copy()
            subset.rename(columns=col_map, inplace=True)
            frames.append(subset)
        except Exception as e:
            print(f"    ⚠ Error: {e}")

    master = pd.concat(frames, axis=1)
    master.index = pd.to_datetime(master.index)
    master.index.name = "Date"
    print(f"\n  Raw shape : {master.shape}")
    print(f"  Date range: {master.index.min().date()} → {master.index.max().date()}")
    return master


