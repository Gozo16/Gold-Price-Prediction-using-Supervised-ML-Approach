]


def get_feature_matrix(df):
    drop = [c for c in EXCLUDE_COLS if c in df.columns]
    X   = df.drop(columns=drop)
    y_ret = df["Target_Return"]
    y_prc = df["Target_Price"]
    y_dir = df["Target_Direction"]
    return X, y_ret, y_prc, y_dir


def build_models():
    models = {
        "Ridge": Ridge(alpha=10.0),
        "RandomForest": RandomForestRegressor(
            n_estimators=400, max_depth=8, min_samples_leaf=10,
