def launch_colab_tool(forecast_df, signals, results, best_name, processed_df):
    if not WIDGETS_AVAILABLE:
        print("  ipywidgets not available — pip install ipywidgets"); return

    banner("STAGE 8 — INTERACTIVE INVESTOR TOOL")

