            reg_alpha=0.5, reg_lambda=2.0, min_child_samples=20,
            random_state=42, n_jobs=-1, verbose=-1)
    return models


def direction_metrics(y_true_ret, y_pred_ret, threshold=0.0):
    """
    Convert regression predictions to directional classifications.
    Actual direction  = sign of actual return  (1=up, 0=down)
    Predicted direction = sign of predicted return (1=up, 0=down)
    threshold: minimum predicted return to count as 'UP' signal.
               0.0 = any positive return counts.
    """
    act_dir  = (y_true_ret  > threshold).astype(int)
    pred_dir = (y_pred_ret  > threshold).astype(int)
    acc  = accuracy_score(act_dir, pred_dir)
    prec = precision_score(act_dir, pred_dir, zero_division=0)
    rec  = recall_score(act_dir, pred_dir, zero_division=0)
    f1   = f1_score(act_dir, pred_dir, zero_division=0)
    cm   = confusion_matrix(act_dir, pred_dir)
    try:
        auc = roc_auc_score(act_dir, y_pred_ret)
    except Exception:
        auc = 0.5
    return {"acc": acc, "prec": prec, "rec": rec, "f1": f1,
            "auc": auc, "cm": cm, "act_dir": act_dir, "pred_dir": pred_dir}


def train_and_evaluate(processed_df, verbose=True):
    banner("STAGE 4 — MODEL TRAINING & EVALUATION")

    X, y_ret, y_prc, y_dir = get_feature_matrix(processed_df)

    split_idx = int(len(X) * 0.80)
    X_train, X_test   = X.iloc[:split_idx],      X.iloc[split_idx:]
    y_train, y_test   = y_ret.iloc[:split_idx],   y_ret.iloc[split_idx:]
    yp_train, yp_test = y_prc.iloc[:split_idx],   y_prc.iloc[split_idx:]

    if verbose:
        print(f"  Train: {X_train.index[0].date()} → {X_train.index[-1].date()} ({len(X_train):,} rows)")
        print(f"  Test : {X_test.index[0].date()}  → {X_test.index[-1].date()} ({len(X_test):,} rows)")
        print(f"  Features : {X_train.shape[1]}")

    scaler  = StandardScaler()
    Xtr_s   = scaler.fit_transform(X_train)
    Xte_s   = scaler.transform(X_test)

    models  = build_models()
    results = {}

    for name, model in models.items():
        if verbose:
            print(f"\n  Training {name}…", end=" ", flush=True)

        model.fit(Xtr_s, y_train)
        pred_ret = model.predict(Xte_s)

        # Reconstruct prices: price[t] = price[t-1] * (1 + predicted_return[t])
        prev_prices = processed_df["Gold_Close"].iloc[split_idx-1 : split_idx + len(X_test) - 1].values
        pred_price  = prev_prices * (1 + pred_ret)

        # ── Regression Metrics ───────────────────────────────────────────────
        mae  = mean_absolute_error(yp_test.values, pred_price)
        rmse = np.sqrt(mean_squared_error(yp_test.values, pred_price))
        mape = np.mean(np.abs((yp_test.values - pred_price) / yp_test.values)) * 100
        r2   = r2_score(y_test.values, pred_ret)      # R² on RETURNS (honest)
        r2p  = r2_score(yp_test.values, pred_price)   # R² on prices (context only)

        # ── Directional / Classification Metrics ────────────────────────────
        dm   = direction_metrics(y_test.values, pred_ret)

        # ── TimeSeriesSplit Cross-Validation ─────────────────────────────────
        tscv     = TimeSeriesSplit(n_splits=N_SPLITS)
        cv_scores= cross_val_score(model, Xtr_s, y_train,
                                   cv=tscv, scoring="neg_mean_absolute_error", n_jobs=-1)
        cv_mae   = -cv_scores.mean()
        cv_std   = cv_scores.std()

        results[name] = {
            "model": model, "pred_ret": pred_ret, "pred_price": pred_price,
            "MAE": mae, "RMSE": rmse, "MAPE": mape,
            "R2": r2, "R2_Price": r2p,
            "CV_MAE": cv_mae, "CV_Std": cv_std,
            "DirectionAcc":  dm["acc"],
            "Precision":     dm["prec"],
            "Recall":        dm["rec"],
            "F1":            dm["f1"],
            "AUC_ROC":       dm["auc"],
            "ConfMatrix":    dm["cm"],
            "act_dir":       dm["act_dir"],
            "pred_dir":      dm["pred_dir"],
        }

        if verbose:
            print(f"MAE=${mae:.1f}  RMSE=${rmse:.1f}  MAPE={mape:.2f}%  "
                  f"R²(ret)={r2:.4f}  DirAcc={dm['acc']*100:.1f}%  "
                  f"F1={dm['f1']:.3f}  AUC={dm['auc']:.3f}  CV_MAE=${cv_mae:.1f}")

    # ── Ensemble: average top-2 models by MAPE ───────────────────────────────
    sorted_by_mape = sorted(results, key=lambda k: results[k]["MAPE"])
    top2 = sorted_by_mape[:2]
    ens_ret   = np.mean([results[m]["pred_ret"]   for m in top2], axis=0)
    ens_price = np.mean([results[m]["pred_price"] for m in top2], axis=0)

    mae  = mean_absolute_error(yp_test.values, ens_price)
    rmse = np.sqrt(mean_squared_error(yp_test.values, ens_price))
    mape = np.mean(np.abs((yp_test.values - ens_price) / yp_test.values)) * 100
    r2   = r2_score(y_test.values, ens_ret)
    r2p  = r2_score(yp_test.values, ens_price)
    dm   = direction_metrics(y_test.values, ens_ret)
    cv_m = np.mean([results[m]["CV_MAE"] for m in top2])

    results["Ensemble"] = {
        "model": None, "pred_ret": ens_ret, "pred_price": ens_price,
        "MAE": mae, "RMSE": rmse, "MAPE": mape,
        "R2": r2, "R2_Price": r2p,
        "CV_MAE": cv_m, "CV_Std": 0,
        "DirectionAcc":  dm["acc"],
        "Precision":     dm["prec"],
        "Recall":        dm["rec"],
        "F1":            dm["f1"],
        "AUC_ROC":       dm["auc"],
        "ConfMatrix":    dm["cm"],
        "act_dir":       dm["act_dir"],
        "pred_dir":      dm["pred_dir"],
        "components":    top2,
    }
    if verbose:
        print(f"\n  Ensemble ({'+'.join(top2)}): MAE=${mae:.1f}  RMSE=${rmse:.1f}  "
              f"MAPE={mape:.2f}%  R²={r2:.4f}  DirAcc={dm['acc']*100:.1f}%")

    best_name = min(results, key=lambda k: results[k]["MAPE"])
    if verbose:
        print(f"\n  ✔ Best model : {best_name}  (lowest MAPE = {results[best_name]['MAPE']:.2f}%)")

    return results, best_name, X_train, X_test, y_test, yp_test, scaler, X.columns.tolist()


