def generate_investor_signals(forecast_df, results, best_name, processed_df):
    banner("STAGE 6 — INVESTOR SIGNAL GENERATION")

    mape    = results[best_name]["MAPE"]
    lp      = processed_df["Gold_Close"].iloc[-1]
    f       = forecast_df["Forecast"]
    t30     = (f.iloc[-1] - lp) / lp * 100
    t3      = (f.iloc[2]  - lp) / lp * 100
    fvol    = forecast_df["PctChange"].std()

    if t30 > 1.5:
        sig, reason = "BUY",         "Model projects sustained upward momentum over 30 days."
    elif t30 < -1.5:
        sig, reason = "SELL / AVOID","Model projects declining prices over 30 days."
    else:
        sig, reason = "HOLD / WAIT", "Model projects sideways movement — wait for clearer signal."

    conf   = max(0, min(100, 100 - mape * 4))
    risk   = "LOW" if fvol < 0.3 else ("HIGH" if fvol > 0.7 else "MEDIUM")
    buy_d  = forecast_df["Forecast"].idxmin()
    sell_d = forecast_df["Forecast"].idxmax()
    buy_p  = forecast_df["Forecast"].min()
    sell_p = forecast_df["Forecast"].max()
    three  = forecast_df.head(3)[["Forecast","PctChange"]].copy()
    three["Action"] = three["PctChange"].apply(
        lambda x: "▲ UP" if x > 0.1 else ("▼ DOWN" if x < -0.1 else "→ FLAT"))

    da = results[best_name]["DirectionAcc"] * 100

    signals = dict(
        overall_signal=sig, reasoning=reason, confidence=conf,
        risk=risk, trend_30d=t30, trend_3d=t3, forecast_vol=fvol,
        buy_day=buy_d, sell_day=sell_d, buy_price=buy_p, sell_price=sell_p,
        three_day=three, last_price=lp, mape=mape, direction_acc=da,
    )

    sep = "─"*60
    print(f"\n{'═'*60}")
    print(f"  ◆ GOLD INVESTOR INTELLIGENCE REPORT")
    print(f"  Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    print(f"{'═'*60}")
    print(f"\n  Current Gold Price  : ${lp:,.2f} / oz")
    print(f"  Best Model          : {best_name}")
    print(f"  MAPE                : {mape:.2f}%")
    print(f"  Directional Acc     : {da:.1f}%  (>52% = commercially useful)")
    print(f"  Confidence          : {conf:.0f}/100")
    print(f"\n  {sep}")
    print(f"  ▶  SIGNAL   : {sig}")
    print(f"     {reason}")
    print(f"     30-Day   : {'▲' if t30>0 else '▼'} {abs(t30):.1f}%  |  "
          f"3-Day: {'▲' if t3>0 else '▼'} {abs(t3):.1f}%")
    print(f"  {sep}")
    print(f"  📅 BEST BUY  : {buy_d.strftime('%A, %d %b %Y')}  @ ${buy_p:,.2f}")
    print(f"  📅 BEST SELL : {sell_d.strftime('%A, %d %b %Y')}  @ ${sell_p:,.2f}")
    print(f"     Potential gain : {(sell_p-buy_p)/buy_p*100:.1f}%")
    print(f"  {sep}")
    print(f"  ⚠  RISK LEVEL: {risk}  (forecast vol={fvol:.2f}%/day)")
    print(f"  {sep}")
    print(f"\n  3-DAY DAILY BREAKDOWN:")
    print(f"  {'Date':<18} {'Forecast':>10} {'Change':>8} {'Signal':>8}")
    print(f"  {'─'*44}")
    for dt, row in three.iterrows():
        print(f"  {dt.strftime('%a %d %b %Y'):<18} ${row['Forecast']:>9,.2f} "
              f"{row['PctChange']:>+7.2f}% {row['Action']:>8}")
    print(f"\n  ⓘ  Model forecasts — not financial advice.\n{'═'*60}\n")
    return signals


